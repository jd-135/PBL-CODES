rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && request.auth.token.email.matches('.*@bitsathy\\.ac\\.in');
    }

    function requesterUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && requesterUser().data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /chat_messages/{id} {
      allow read, create: if signedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /queries/{id} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if signedIn();
      allow update: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /activity_log/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /lc_entries/{id} {
      allow read, create: if signedIn();
      allow update, delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /tasks/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
